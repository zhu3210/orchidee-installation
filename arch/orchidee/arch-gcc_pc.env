unset LD_LIBRARY_PATH

# Compilers
export CC=gcc
export CXX=g++
export FC=gfortran

# Spack environment
source ~/spack/share/spack/setup-env.sh

# Load the tested dependency stack.
# If Spack reports multiple matches, use `spack find -l <package>` and add the hash.
spack load openmpi@4.0.7
spack load hdf5@1.10.7
spack load netcdf-c@4.7.4
spack load netcdf-fortran@4.5.3

